// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "features": {
    "edit_prediction_provider": "zed"
  },
  "file_scan_exclusions": [
    "**/.raintmp",
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings"
  ],
  "edit_predictions": {
    "disabled_globs": [".env", "**/*.md"]
  },
  "languages": {
    "Markdown": {
      "show_edit_predictions": false
    }
  },
  "assistant": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-5-sonnet-latest"
    },
    "version": "2"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "Noto Sans Mono Rain 95",
  "buffer_font_weight": 500,
  "ui_font_family": "Cantarell",
  "ui_font_size": 16,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Gruvbox Dark Hard"
  },
  "tab_bar": {
    "show": false
  },
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "ignore_system_version": true
      }
    },
    "initialization_options": {
      "references": {
        "excludeImports": true
      },
      "cachePriming": {
        "enable": true
      },
      "completion": {
        "privateEditable": {
          "enable": true
        }
      },
      "diagnostics": {
        "enable": false,
        "experimental": {
          "enable": false
        }
      }
    }
  },
  "use_system_path_prompts": false,
  "cursor_blink": false,
  "ssh_connections": [
    {
      "host": "sunshowers-illumos.echoes",
