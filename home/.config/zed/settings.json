// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "assistant": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-3-5-sonnet"
    },
    "version": "2"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "Noto Sans Mono Rain 95",
  "buffer_font_weight": 500,
  "ui_font_family": "Cantarell",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Gruvbox Dark"
  },
  "tab_bar": {
    "show": false
  },
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "ignore_system_version": true
      }
    }
  },
  "use_system_path_prompts": false,
  "cursor_blink": false,
  "ssh_connections": [
    {
      "host": "sunshowers-illumos.echoes",
      "projects": [
        {
          "paths": [
            "~/dev"
          ]
        },
        {
          "paths": [
            "~/dev/oxide/omicron"
          ]
        }
      ]
    },
    {
      "host": "sunshowers-linux-dev",
      "projects": [
        {
          "paths": [
            "~/dev/config-rs"
          ]
        },
        {
          "paths": [
            "~/dev/guppy"
          ]
        },
        {
          "paths": [
            "~/dev/indent-write"
          ]
        },
        {
          "paths": [
            "~/dev/ipc-channel"
          ]
        },
        {
