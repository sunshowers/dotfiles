            "~/dev/nextest-rs/datatest-stable"
          ]
        },
        {
          "paths": [
            "~/dev/nextest-rs/mukti"
          ]
        },
        {
          "paths": [
            "~/dev/nextest-rs/nextest"
          ]
        },
        {
